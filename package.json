{
  "name": "webdiagtool",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:web": "vite --config client/vite.config.ts",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p server/tsconfig.json",
    "build:web": "vite build --config client/vite.config.ts",
    "typecheck": "tsc --noEmit -p server/tsconfig.json && tsc --noEmit -p client/tsconfig.json",
    "cli": "tsx server/src/cli.ts",
    "cli:json": "tsx server/src/cli.ts -o json",
    "cli:md": "tsx server/src/cli.ts -o markdown",
    "cli:html": "tsx server/src/cli.ts -o html",
    "start": "npm run build && node server/dist/index.js",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist data"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.75.0",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "adm-zip": "^0.5.16",
    "cheerio": "^1.0.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "simple-git": "^3.36.0",
    "sql.js": "^1.11.0",
    "superjson": "^2.2.6",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/adm-zip": "^0.5.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
